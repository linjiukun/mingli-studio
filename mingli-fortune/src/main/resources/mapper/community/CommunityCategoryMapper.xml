<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mingli.fortune.mapper.CommunityCategoryMapper">

    <resultMap id="CategoryResult" type="com.mingli.fortune.domain.CommunityCategory">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectCategoryVo">
        SELECT id, name, description, sort_order, status, create_time
        FROM community_category
    </sql>

    <select id="selectCategoryList" parameterType="com.mingli.fortune.domain.CommunityCategory" resultMap="CategoryResult">
        <include refid="selectCategoryVo"/>
        <where>
            <if test="name != null and name != ''">AND name LIKE CONCAT('%', #{name}, '%')</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        ORDER BY sort_order ASC
    </select>

    <select id="selectAllCategories" resultMap="CategoryResult">
        <include refid="selectCategoryVo"/>
        WHERE status = '0'
        ORDER BY sort_order ASC
    </select>

    <select id="selectCategoryById" parameterType="Long" resultMap="CategoryResult">
        <include refid="selectCategoryVo"/>
        WHERE id = #{id}
    </select>

    <insert id="insertCategory" parameterType="com.mingli.fortune.domain.CommunityCategory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO community_category (name, description, sort_order, status, create_time)
        VALUES (#{name}, #{description}, #{sortOrder}, #{status}, #{createTime})
    </insert>

    <update id="updateCategory" parameterType="com.mingli.fortune.domain.CommunityCategory">
        UPDATE community_category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteCategoryById" parameterType="Long">
        DELETE FROM community_category WHERE id = #{id}
    </delete>

    <select id="checkCategoryNameUnique" resultType="int">
        SELECT COUNT(*) FROM community_category WHERE name = #{name}
        <if test="id != null">AND id != #{id}</if>
    </select>

</mapper>